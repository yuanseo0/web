<script src="https://cdnjs.cloudflare.com/ajax/libs/handlebars.js/4.7.7/handlebars.min.js"></script>

<div class="my-5">
    <h1 class="text-center">교수관리</h1>
    <div class="text-end mb-3">
        <button class="btn btn-primary px-5" onclick="location.href='/haksa/pro/insert'">교수 등록</button>
    </div>
    
    <table id="tbl" class="table table-striped table-bordered text-center"></table>

    <script id="temp" type="x-handlebars-template">
        <thead>
            <tr class="table-dark">
                <th>교수코드</th>
                <th>교수이름</th>
                <th>소속학과</th>
                <th>임용일자</th>
                <th>직급</th>
                <th>급여</th>
                <th>삭제</th>
            </tr>
        </thead>
        <tbody>
            {{#each .}}
            <tr>
                <td>{{PCODE}}</td>
                <td>{{PNAME}}</td>
                <td>{{DEPT}}</td>
                <td>{{FDATE}}</td>
                <td>{{TITLE}}</td>
                <td>{{FSALARY}}원</td>
                <td><button pcode="{{PCODE}}" pname="{{PNAME}}" class="btn btn-outline-danger btn-sm btn-delete">삭제</button></td>
            </tr>
            {{/each}}
        </tbody>
    </script>
</div>

<script>
    // 페이지 로딩 시 목록 불러오기
    getList();

    // 삭제 버튼 클릭 이벤트 (위임 방식)
    $("#tbl").on("click", ".btn-delete", function(){
        const pcode = $(this).attr("pcode");
        const pname = $(this).attr("pname");

        if(confirm(`${pname}(${pcode}) 교수를 삭제하실래요?`)){
            $.ajax({
                type: "post",
                url: "/haksa/pro/delete",
                data: { pcode: pcode },
                success: function(){
                    alert("삭제되었습니다.");
                    getList(); // 목록 새로고침
                },
                error: function(){
                    alert("삭제 실패! 서버 연결을 확인하세요.");
                }
            });
        }
    });

    // 목록 가져오기 함수
    function getList(){
        $.ajax({
            type: "get",
            url: "/haksa/pro/list.json",
            success: function(data){
                // 강감찬 필터링 코드를 완전히 제거했습니다. 모든 교수가 다 보입니다.
                const temp = Handlebars.compile($("#temp").html());
                $("#tbl").html(temp(data));
            },
            error: function(){
                alert("데이터 로딩 실패!");
            }
        });
    }
</script>