<div class="my-5">
    <h1 class="text-center">학생등록</h1>
    <div class="row justify-content-center">
        <form class="col-sm-10 col-md-6" name="frm" method="post">
            <div class="input-group mb-2">
                <span class="input-group-text">학생번호</span>
                <!-- readonly를 사용해야 서버로 값이 넘어갑니다. -->
                <input name="scode" class="form-control" readonly value="<%=code%>">
            </div>
            <div class="input-group mb-2">
                <span class="input-group-text">학생이름</span>
                <input name="sname" class="form-control" placeholder="이름을 입력하세요">
            </div>
            <div class="input-group mb-2">
                <span class="input-group-text">학생학과</span>
                <select name="dept" class="form-select">
                    <option value="전산">전산</option>
                    <option value="전자">전자</option>
                    <option value="건축">건축</option>
                </select>
            </div>
            <div class="input-group mb-2">
                <span class="input-group-text">학생학년</span>
                <select name="year" class="form-select">
                    <option value="1">1학년</option>
                    <option value="2" selected>2학년</option>
                    <option value="3">3학년</option>
                    <option value="4">4학년</option>
                </select>
            </div>
            <div class="input-group mb-2">
                <span class="input-group-text">생년월일</span>
                <input name="birthday" class="form-control" type="date" value="2006-01-01">
            </div>
            <div class="input-group mb-2">
                <span class="input-group-text">지도교수</span>
                <input name="pcode" class="form-control" placeholder="교수번호" readonly>
                <%-include("professors_modal.ejs")%>
            </div>
            <div class="text-center mt-3">
                <button type="submit" class="btn btn-primary px-3">학생등록</button>
                <button type="reset" class="btn btn-secondary px-3">등록취소</button>
            </div>
        </form>
    </div>
</div>

<script>
    // 폼이 전송될 때 실행되는 이벤트
    $(frm).on("submit", function(e){
        e.preventDefault(); // 기본 submit 막기 (AJAX 사용 위함)
        
        const scode = $(frm.scode).val();
        const sname = $(frm.sname).val();
        const dept = $(frm.dept).val();
        const birthday = $(frm.birthday).val();
        const year = $(frm.year).val();
        const pcode = $(frm.pcode).val();

        // 입력 체크
        if(sname == ""){
            alert("학생이름을 입력하세요!");
            $(frm.sname).focus();
            return;
        }

        if(pcode == ""){
            alert("지도교수를 선택하세요!");
            return;
        }

        if(!confirm(`${sname} 학생을 등록하시겠습니까?`)) return;

        // AJAX를 이용한 서버 전송
        $.ajax({
            type: "post",
            url: "/haksa/stu/insert",
            data: { 
                scode: scode, 
                sname: sname, 
                dept: dept, 
                birthday: birthday, 
                year: year, 
                pcode: pcode 
            },
            success: function(){
                alert("학생등록이 완료되었습니다.");
                location.href = "/haksa/stu"; // 등록 성공 시 목록으로 이동
            },
            error: function(err){
                alert("등록 실패! 서버 로그를 확인하세요.");
                console.log(err);
            }
        });
    });
</script>